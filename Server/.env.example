# Database Configuration
# For local MongoDB:
# MONGODB_URI=mongodb://localhost:27017/metameet

# For MongoDB Atlas (cloud):
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/Metameet

# JWT Configuration
# Generate a secure secret with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-secure-jwt-secret-generate-with-crypto-randomBytes
JWT_EXPIRES_IN=15m

# Server Configuration
PORT=3000
NODE_ENV=development

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app,https://*.vercel.app
